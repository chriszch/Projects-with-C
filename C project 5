#include <stdio.h>
#include <string.h>

int main(){
    
    int i;
    int num;
    
    printf("digite o numero que deseja ver as tabuadas: ");
    scanf("%d",&num);
    
    printf("\n----tabuada da adicao----\n");
    for(i=1; i<=10; i++){
        printf("\n%d + %d = %d\n",num,i,num + i);
    }
    printf("\n----tabuada da subtracao----\n");
    for(i=1; i<=10; i++){
        printf("\n%d - %d = %d\n",num,i,num - i);
    }
    printf("\n----tabuada da multiplicacao----\n");
    for(i=1; i<=10; i++){
        printf("\n%d x %d = %d\n",num,i,num * i);
    }
    printf("\n----tabuada da divisao----\n");
    for(i=1; i<=10; i++){
        float divisao = (float)num / i;
        printf("\n%d / %d = %.2f\n",num,i,divisao);
    }
    
    printf("\n--------------------------\n");
    
    return 0;
}

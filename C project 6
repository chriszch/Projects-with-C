#include <stdio.h>
#include <string.h>
int main(){
    
    int idade;
    int soma = 0;
    int contador = 0;
    float media;
    
    printf("\n----media de idades----\n");
    printf("digite '0' quando desejar encerrar e ver a media.\n");
    
    while(1){
        printf("qual a sua idade? ");
        scanf("%d",&idade);
        
        if(idade == 0){
            break;
        }
        
        soma = soma + idade;
        contador = contador + 1;
    }
    if(contador > 0){
        media = (float)soma / contador;
        printf("a quantidade de idades digitadas e: %d\n",contador);
        printf("a media das idades e: %.2f\n",media);
        
    }
    else{
        printf("nenhuma idade valida foi digitada");
    }
    
    return 0;
    
    
    
}
